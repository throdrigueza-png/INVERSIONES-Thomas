// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Ojo: Ya no va la línea de "url =" aquí.
}

// ==========================================
// ENUMS
// ==========================================
enum TransactionSource {
  LIQUID
  CREDIT_CARD
}

// ==========================================
// NEXTAUTH: Modelos de Autenticación
// ==========================================
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Relaciones con datos financieros del usuario
  profile      UserProfile?
  transactions WalletTransaction[]
  investments  Investment[]
  creditCards  CreditCard[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 1. PERFIL Y BILLETERA LÍQUIDA (por usuario)
// ==========================================
model UserProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  liquidBalance Float    @default(0) // Tu plata intocable a la mano
  updatedAt     DateTime @updatedAt
}

// ==========================================
// 2. HISTORIAL DE GASTOS HORMIGA / INGRESOS (por usuario)
// ==========================================
model WalletTransaction {
  id           String            @id @default(uuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       Float
  type         String            // "IN" o "OUT"
  description  String
  date         DateTime          @default(now())
  source       TransactionSource @default(LIQUID)
  creditCardId String?
  creditCard   CreditCard?       @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
}

// ==========================================
// 3. FONDOS DE INVERSIÓN (por usuario)
// ==========================================
model Investment {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  category      String   // "PASIVA" o "ACTIVA"
  color         String
  initialAmount Float
  currentAmount Float
  minBalance    Float    @default(0)
  isLiquid      Boolean  @default(true)
  createdAt     DateTime @default(now())

  // Relación: Una inversión tiene muchos puntos en el historial (Gráficas)
  history       InvestmentHistory[]
}

// ==========================================
// 4. HISTORIAL DE RENTABILIDAD (Para las gráficas y deshacer)
// ==========================================
model InvestmentHistory {
  id           String     @id @default(uuid())
  investmentId String
  investment   Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  value        Float
  type         String     @default("SNAPSHOT") // SNAPSHOT | ADD | WITHDRAW | RETURN
  delta        Float      @default(0)          // Cambio en currentAmount (negativo si fue pérdida en RETURN)
  deltaInitial Float      @default(0)          // Cambio real en initialAmount (puede ser menor que delta en WITHDRAW)
  date         DateTime   @default(now())
}

// ==========================================
// 5. TARJETAS DE CRÉDITO (por usuario)
// ==========================================
model CreditCard {
  id           String             @id @default(uuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String             // Ej: Nu, Bancolombia
  creditLimit  Float              // Cupo total
  cutOffDate   Int                // Día de corte (1-31)
  paymentDate  Int                // Día de pago (1-31)
  currentDebt  Float              @default(0) // Deuda actual
  createdAt    DateTime           @default(now())
  transactions WalletTransaction[]
}